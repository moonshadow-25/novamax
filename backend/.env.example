# 后端环境变量模板，复制为 .env 后修改
PORT=3001

# 各通道更新服务器地址
REMOTE_SERVER_URL_STABLE=https://www.firstarpc.com/download/novamax/
REMOTE_SERVER_URL_BETA=https://www.firstarpc.com/download/novamax/test/
REMOTE_SERVER_URL_DEV=https://www.firstarpc.com/download/novamax/dev/

# 远程配置路径
REMOTE_MODELS_PATH=models.json
REMOTE_ENGINES_PATH=engines.json
