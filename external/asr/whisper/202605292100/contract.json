{
  "contract_version": "1.0",
  "engine": {
    "type": "whisper",
    "name": "Whisper.cpp",
    "version": "1.0.0",
    "description": "OpenAI Whisper 语音识别引擎 (基于 whisper.cpp)",
    "vendor": "Whisper.cpp"
  },
  "capabilities": {
    "model_formats": ["ggml"],
    "supported_languages": ["auto", "zh", "en", "ja", "ko", "fr", "de", "es", "ru", "pt", "it", "nl", "ar", "tr", "pl", "sv", "uk", "vi", "th", "ca", "hi"],
    "output_formats": ["json", "text", "srt", "verbose_json", "vtt"],
    "supports_streaming": false,
    "supports_vad": true,
    "supports_translation": false,
    "supports_timestamps": true,
    "max_audio_duration_seconds": 7200,
    "max_file_size_mb": 500,
    "max_concurrency": 1,
    "sample_rate": 16000
  },
  "runtime_config": {
    "threads": { "default": 4, "min": 1, "max": 16, "step": 1, "label": "CPU 线程数" },
    "language": { "default": "auto", "label": "默认语言" }
  },
  "memory_profile": {
    "base_ram_mb": 2000,
    "supports_clear_cache": false,
    "supports_memory_info": false
  }
}
